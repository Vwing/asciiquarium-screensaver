#include <windows.h>
#include <scrnsave.h>

// scrnsave.lib requires a dialog with ID DLG_SCRNSAVECONFIGURE (2003)
DLG_SCRNSAVECONFIGURE DIALOG 0, 0, 200, 80
STYLE DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Asciiquarium Screensaver"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT  "Asciiquarium Screensaver", -1, 10, 14, 180, 10
    LTEXT  "An aquarium/sea animation in ASCII art.", -1, 10, 28, 180, 10
    DEFPUSHBUTTON "OK", IDOK, 75, 58, 50, 14
END
